{
  "name": "@openclaw/gateway-protocol",
  "version": "0.0.0-private",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.ts",
      "default": "./dist/index.ts"
    },
    "./client-info": {
      "types": "./dist/client-info.d.ts",
      "import": "./dist/client-info.ts",
      "default": "./dist/client-info.ts"
    },
    "./connect-error-details": {
      "types": "./dist/connect-error-details.d.ts",
      "import": "./dist/connect-error-details.ts",
      "default": "./dist/connect-error-details.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.ts",
      "default": "./dist/schema.ts"
    },
    "./startup-unavailable": {
      "types": "./dist/startup-unavailable.d.ts",
      "import": "./dist/startup-unavailable.ts",
      "default": "./dist/startup-unavailable.ts"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.ts",
      "default": "./dist/version.ts"
    }
  },
  "scripts": {
    "build": "tsc src/index.ts src/client-info.ts src/connect-error-details.ts src/schema.ts src/startup-unavailable.ts src/version.ts --no-config --platform node --format esm --dts --out-dir dist --clean"
  },
  "dependencies": {
    "typebox": "1.1.39"
  }
}
