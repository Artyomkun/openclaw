{
  "name": "@openclaw/net-policy",
  "version": "0.0.0-private",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.ts",
      "default": "./dist/index.ts"
    },
    "./ip": {
      "types": "./dist/ip.d.ts",
      "import": "./dist/ip.ts",
      "default": "./dist/ip.ts"
    },
    "./ipv4": {
      "types": "./dist/ipv4.d.ts",
      "import": "./dist/ipv4.ts",
      "default": "./dist/ipv4.ts"
    },
    "./redact-sensitive-url": {
      "types": "./dist/redact-sensitive-url.d.ts",
      "import": "./dist/redact-sensitive-url.ts",
      "default": "./dist/redact-sensitive-url.ts"
    },
    "./url-userinfo": {
      "types": "./dist/url-userinfo.d.ts",
      "import": "./dist/url-userinfo.ts",
      "default": "./dist/url-userinfo.ts"
    }
  },
  "scripts": {
    "build": "tsc src/index.ts src/ip.ts src/ipv4.ts src/redact-sensitive-url.ts src/url-userinfo.ts --no-config --platform node --format esm --dts --out-dir dist --clean"
  },
  "dependencies": {
    "ipaddr.js": "2.4.0"
  }
}
